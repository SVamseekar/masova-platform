# ============================================
# MaSoVa Restaurant Management System
# Environment Variables Configuration
# ============================================

# --------------------------------------------
# JWT Configuration (CRITICAL - Must be same across all services!)
# --------------------------------------------
JWT_SECRET=MaSoVa-secret-key-for-jwt-token-generation-very-long-key-must-be-at-least-256-bits-for-production-security

# --------------------------------------------
# MongoDB Configuration
# --------------------------------------------
# User Service Database
MONGODB_USER_URI=mongodb://localhost:27017/masova
MONGODB_USER_DATABASE=masova

# Menu Service Database
MONGODB_MENU_URI=mongodb://localhost:27017/masova_menu
MONGODB_MENU_DATABASE=masova_menu

# Order Service Database
MONGODB_ORDER_URI=mongodb://localhost:27017/masova_orders
MONGODB_ORDER_DATABASE=masova_orders

# Delivery Service Database
MONGODB_DELIVERY_URI=mongodb://localhost:27017/delivery_db
MONGODB_DELIVERY_DATABASE=delivery_db

# --------------------------------------------
# Redis Configuration (Caching)
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=8

# --------------------------------------------
# Service URLs (for inter-service communication)
# --------------------------------------------
API_GATEWAY_URL=http://localhost:8080
USER_SERVICE_URL=http://localhost:8081
MENU_SERVICE_URL=http://localhost:8082
ORDER_SERVICE_URL=http://localhost:8083
CUSTOMER_SERVICE_URL=http://localhost:8084
ANALYTICS_SERVICE_URL=http://localhost:8085
PAYMENT_SERVICE_URL=http://localhost:8086
INVENTORY_SERVICE_URL=http://localhost:8088
REVIEW_SERVICE_URL=http://localhost:8089
DELIVERY_SERVICE_URL=http://localhost:8090
NOTIFICATION_SERVICE_URL=http://localhost:8092

# --------------------------------------------
# Frontend URLs (for CORS and Email Links)
# --------------------------------------------
# Used for generating tracking links in order confirmation emails
FRONTEND_URL=https://masova-restaurant.vercel.app
# Legacy URL for React frontend (if applicable)
FRONTEND_BASE_URL=https://masova-restaurant.vercel.app

# --------------------------------------------
# Business Configuration
# --------------------------------------------
# Default store ID for development
DEFAULT_STORE_ID=store-001

# Tax rate (percentage)
TAX_RATE=5.0

# Delivery fee (in INR)
DELIVERY_FEE=40

# Minimum order value for delivery (in INR)
MIN_ORDER_VALUE=100

# --------------------------------------------
# External Services (Optional - for future phases)
# --------------------------------------------
# Google Maps API (for driver navigation)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# SMS Service (for notifications)
SMS_API_KEY=your-sms-api-key-here
SMS_SENDER_ID=MASOVA

# --------------------------------------------
# Email Service - Brevo (Transactional Email)
# --------------------------------------------
# REQUIRED for order confirmation and payment confirmation emails
# Get your API key from https://app.brevo.com/settings/keys/api
# Sign up at https://app.brevo.com (free tier available)
BREVO_API_KEY=REDACTED_BREVO_API_KEY
BREVO_FROM_EMAIL=vamseesoura56@gmail.com
BREVO_FROM_NAME=MaSoVa Restaurant
# Set to true to enable email notifications (order confirmation + payment confirmation)
BREVO_ENABLED=true

# Brevo Free Tier Limits:
# - 300 emails per day (enough for ~150 orders/day with 2 emails per order)
# - 9,000 emails per month
# - Emails include "Sent with Brevo" branding
# - Upgrade to Lite plan ($25/month) to remove branding and increase limits
BREVO_DAILY_LIMIT=300

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_ENABLED=false

# Payment Gateway - Razorpay (Phase 5)
# Get your keys from https://dashboard.razorpay.com/app/keys
# Test credentials - replace with production keys for live environment
RAZORPAY_KEY_ID=rzp_test_RjYYkXMmoArj4C
RAZORPAY_KEY_SECRET=Asbe0hf12kZn0VSX4ykn3Nvq
RAZORPAY_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# --------------------------------------------
# Application Environment
# --------------------------------------------
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev

# --------------------------------------------
# Logging Configuration
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs

# --------------------------------------------
# Security Settings
# --------------------------------------------
# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Rate limiting (requests per minute per user)
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Session timeout (in milliseconds)
SESSION_TIMEOUT=3600000

# Refresh token expiration (in milliseconds - 7 days)
REFRESH_TOKEN_EXPIRATION=604800000

# Access token expiration (in milliseconds - 1 hour)
ACCESS_TOKEN_EXPIRATION=3600000
