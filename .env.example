# ============================================
# MaSoVa Restaurant Management System
# Environment Variables Configuration
# ============================================

# --------------------------------------------
# JWT Configuration (CRITICAL - Must be same across all services!)
# --------------------------------------------
JWT_SECRET=MaSoVa-secret-key-for-jwt-token-generation-very-long-key-must-be-at-least-256-bits-for-production-security

# --------------------------------------------
# MongoDB Configuration
# --------------------------------------------
# User Service Database
MONGODB_USER_URI=mongodb://localhost:27017/masova
MONGODB_USER_DATABASE=masova

# Menu Service Database
MONGODB_MENU_URI=mongodb://localhost:27017/masova_menu
MONGODB_MENU_DATABASE=masova_menu

# Order Service Database
MONGODB_ORDER_URI=mongodb://localhost:27017/masova_orders
MONGODB_ORDER_DATABASE=masova_orders

# --------------------------------------------
# Redis Configuration (Caching)
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=8

# --------------------------------------------
# Service URLs (for inter-service communication)
# --------------------------------------------
API_GATEWAY_URL=http://localhost:8080
USER_SERVICE_URL=http://localhost:8081
MENU_SERVICE_URL=http://localhost:8082
ORDER_SERVICE_URL=http://localhost:8083

# --------------------------------------------
# Frontend URLs (for CORS)
# --------------------------------------------
FRONTEND_URL=http://localhost:3000
FRONTEND_VITE_URL=http://localhost:5173

# --------------------------------------------
# Business Configuration
# --------------------------------------------
# Default store ID for development
DEFAULT_STORE_ID=store-001

# Tax rate (percentage)
TAX_RATE=5.0

# Delivery fee (in INR)
DELIVERY_FEE=40

# Minimum order value for delivery (in INR)
MIN_ORDER_VALUE=100

# --------------------------------------------
# External Services (Optional - for future phases)
# --------------------------------------------
# Google Maps API (for driver navigation)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# SMS Service (for notifications)
SMS_API_KEY=your-sms-api-key-here
SMS_SENDER_ID=MASOVA

# Payment Gateway (Phase 5)
PAYMENT_GATEWAY_KEY=your-payment-gateway-key-here
PAYMENT_GATEWAY_SECRET=your-payment-gateway-secret-here

# --------------------------------------------
# Application Environment
# --------------------------------------------
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev

# --------------------------------------------
# Logging Configuration
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs

# --------------------------------------------
# Security Settings
# --------------------------------------------
# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Rate limiting (requests per minute per user)
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Session timeout (in milliseconds)
SESSION_TIMEOUT=3600000

# Refresh token expiration (in milliseconds - 7 days)
REFRESH_TOKEN_EXPIRATION=604800000

# Access token expiration (in milliseconds - 1 hour)
ACCESS_TOKEN_EXPIRATION=3600000
