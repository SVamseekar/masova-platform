{
  "consumer": {
    "name": "masova-frontend"
  },
  "interactions": [
    {
      "description": "a request to get payment status",
      "providerStates": [
        {
          "name": "payment service is available"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer test-token"
        },
        "matchingRules": {
          "header": {
            "Authorization": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^Bearer .+$"
                }
              ]
            }
          }
        },
        "method": "GET",
        "path": "/api/payments/TXN-PACT-1"
      },
      "response": {
        "body": {
          "status": "SUCCESS",
          "transactionId": "TXN-PACT-1"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to initiate a payment",
      "providerStates": [
        {
          "name": "payment service is available"
        }
      ],
      "request": {
        "body": {
          "amount": 450,
          "orderId": "ORDER-PACT-1",
          "paymentMethod": "CARD"
        },
        "headers": {
          "Authorization": "Bearer test-token",
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.amount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.orderId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.paymentMethod": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {
            "Authorization": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^Bearer .+$"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/payments/initiate"
      },
      "response": {
        "body": {
          "status": "PENDING",
          "transactionId": "TXN-PACT-1"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.transactionId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to initiate payment",
      "providerStates": [
        {
          "name": "payment service is available"
        }
      ],
      "request": {
        "body": {
          "amount": 500,
          "customerEmail": "test@masova.com",
          "customerId": "cust-1",
          "orderId": "order-1",
          "orderType": "TAKEAWAY",
          "paymentMethod": "CARD",
          "storeId": "store-1"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.amount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.customerEmail": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.customerId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.orderId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.orderType": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.paymentMethod": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.storeId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/payments/initiate"
      },
      "response": {
        "body": {
          "amount": 500,
          "razorpayKeyId": "rzp_test_key",
          "razorpayOrderId": "order_razorpay_1",
          "status": "INITIATED",
          "transactionId": "txn-1"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.amount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.razorpayKeyId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.razorpayOrderId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.transactionId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to verify payment",
      "providerStates": [
        {
          "name": "payment transaction exists with id txn-1"
        }
      ],
      "request": {
        "body": {
          "razorpayOrderId": "order_razorpay_1",
          "razorpayPaymentId": "pay_razorpay_1",
          "razorpaySignature": "valid_signature"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.razorpayOrderId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.razorpayPaymentId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.razorpaySignature": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/payments/verify"
      },
      "response": {
        "body": {
          "status": "SUCCESS",
          "transactionId": "txn-1"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.transactionId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.0.4"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "payment-service"
  }
}