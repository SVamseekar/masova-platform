{
  "consumer": {
    "name": "masova-frontend"
  },
  "interactions": [
    {
      "description": "a request to get delivery zones",
      "providerStates": [
        {
          "name": "delivery zones configured"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer test-token"
        },
        "matchingRules": {
          "header": {
            "Authorization": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^Bearer .+$"
                }
              ]
            }
          }
        },
        "method": "GET",
        "path": "/api/delivery/zones",
        "query": {
          "storeId": [
            "STORE-PACT-1"
          ]
        }
      },
      "response": {
        "body": [
          {
            "deliveryFeeINR": 29,
            "estimatedDeliveryMinutes": 15,
            "maxDistanceKm": 3,
            "minDistanceKm": 0,
            "zoneName": "A"
          },
          {
            "deliveryFeeINR": 49,
            "estimatedDeliveryMinutes": 25,
            "maxDistanceKm": 6,
            "minDistanceKm": 3,
            "zoneName": "B"
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to track a delivery",
      "providerStates": [
        {
          "name": "delivery tracking exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/delivery/track/ORDER-PACT-1"
      },
      "response": {
        "body": {
          "orderId": "ORDER-PACT-1",
          "orderStatus": "OUT_FOR_DELIVERY"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.orderStatus": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.0.4"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "logistics-service"
  }
}