{
  "consumer": {
    "name": "masova-frontend"
  },
  "interactions": [
    {
      "description": "a request to get store by ID",
      "providerStates": [
        {
          "name": "store exists with id STORE-PACT-1"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer test-token"
        },
        "matchingRules": {
          "header": {
            "Authorization": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^Bearer .+$"
                }
              ]
            }
          }
        },
        "method": "GET",
        "path": "/api/stores/STORE-PACT-1"
      },
      "response": {
        "body": {
          "address": {
            "city": "Berlin"
          },
          "id": "STORE-PACT-1",
          "name": "MaSoVa Berlin"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.address.city": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to get user by ID",
      "providerStates": [
        {
          "name": "user exists with id USER-PACT-1"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer test-token"
        },
        "matchingRules": {
          "header": {
            "Authorization": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^Bearer .+$"
                }
              ]
            }
          }
        },
        "method": "GET",
        "path": "/api/users/USER-PACT-1"
      },
      "response": {
        "body": {
          "email": "john.manager@example.com",
          "id": "USER-PACT-1",
          "name": "John Manager",
          "type": "MANAGER"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.0.4"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "core-service"
  }
}