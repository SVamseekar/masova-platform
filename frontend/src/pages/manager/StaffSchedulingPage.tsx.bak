import React, { useState, useMemo } from 'react';
import { useAppSelector } from '../../store/hooks';
import { selectCurrentUser } from '../../store/slices/authSlice';
import { usePageStore } from '../../contexts/PageStoreContext';
import { withPageStoreContext } from '../../hoc/withPageStoreContext';
import { useSmartBackNavigation } from '../../hooks/useSmartBackNavigation';
import {
  useGetWeeklyScheduleQuery,
  useBulkCreateShiftsMutation,
  useCopyPreviousWeekScheduleMutation,
  useDeleteShiftMutation,
  useUpdateShiftMutation,
  type Shift,
  type CreateShiftRequest,
} from '../../store/api/shiftApi';
import { useGetStoreEmployeesQuery } from '../../store/api/userApi';
import { Card, Button } from '../../components/ui/neumorphic';
import AppHeader from '../../components/common/AppHeader';
import AnimatedBackground from '../../components/backgrounds/AnimatedBackground';
import { colors, spacing, typography, borderRadius } from '../../styles/design-tokens';
import { createNeumorphicSurface, createCard, createBadge } from '../../styles/neumorphic-utils';

// Utility functions for date handling
const getWeekStart = (date: Date): Date => {
  const d = new Date(date);
  const day = d.getDay();
  const diff = d.getDate() - day + (day === 0 ? -6 : 1); // Adjust when day is Sunday
  return new Date(d.setDate(diff));
};

const formatDateForAPI = (date: Date): string => {
  return date.toISOString().split('T')[0]; // YYYY-MM-DD format
};

const formatTime = (date: string): string => {
  return new Date(date).toLocaleTimeString('en-US', {
    hour: '2-digit',
    minute: '2-digit',
    hour12: true,
  });
};

const getDayName = (date: Date): string => {
  return date.toLocaleDateString('en-US', { weekday: 'short' });
};

interface ShiftFormData {
  employeeId: string;
  type: 'OPENING' | 'CLOSING' | 'PEAK' | 'REGULAR' | 'MAINTENANCE' | 'TRAINING' | 'EMERGENCY';
  date: Date;
  startTime: string; // HH:MM format
  endTime: string; // HH:MM format
  notes: string;
  isMandatory: boolean;
}

const StaffSchedulingPage: React.FC = () => {
  const currentUser = useAppSelector(selectCurrentUser);
  const { handleBack } = useSmartBackNavigation();
  const { selectedStoreId } = usePageStore();

  // Get storeId from page-specific context
  const storeId = selectedStoreId || currentUser?.storeId || '';

  // Week navigation state
  const [currentWeekStart, setCurrentWeekStart] = useState<Date>(getWeekStart(new Date()));
  const weekStartStr = formatDateForAPI(currentWeekStart);

  // Dialog states
  const [createShiftDialogOpen, setCreateShiftDialogOpen] = useState(false);
  const [shiftFormData, setShiftFormData] = useState<ShiftFormData>({
    employeeId: '',
    type: 'REGULAR',
    date: new Date(),
    startTime: '09:00',
    endTime: '17:00',
    notes: '',
    isMandatory: true,
  });

  // Bulk creation state
  const [bulkShifts, setBulkShifts] = useState<CreateShiftRequest[]>([]);
  const [bulkCreateDialogOpen, setBulkCreateDialogOpen] = useState(false);

  // API queries and mutations
  const { data: weeklyShifts = [], isLoading: shiftsLoading } = useGetWeeklyScheduleQuery(
    { storeId, startDate: weekStartStr },
    { skip: !storeId }
  );

  const { data: employees = [], isLoading: employeesLoading } = useGetStoreEmployeesQuery(storeId, {
    skip: !storeId,
  });

  const [bulkCreateShifts, { isLoading: bulkCreating }] = useBulkCreateShiftsMutation();
  const [copyPreviousWeek, { isLoading: copying }] = useCopyPreviousWeekScheduleMutation();
  const [deleteShift] = useDeleteShiftMutation();
  const [updateShift] = useUpdateShiftMutation();

  // Filter employees to only show staff and drivers
  const staffMembers = useMemo(() => {
    return employees.filter(
      (emp) =>
        emp.type === 'STAFF' ||
        emp.type === 'DRIVER' ||
        emp.type === 'ASSISTANT_MANAGER'
    );
  }, [employees]);

  // Generate week dates
  const weekDates = useMemo(() => {
    const dates = [];
    for (let i = 0; i < 7; i++) {
      const date = new Date(currentWeekStart);
      date.setDate(date.getDate() + i);
      dates.push(date);
    }
    return dates;
  }, [currentWeekStart]);

  // Group shifts by employee and day
  const shiftsByEmployeeAndDay = useMemo(() => {
    const grouped: Record<string, Record<string, Shift[]>> = {};

    weeklyShifts.forEach((shift) => {
      if (!grouped[shift.employeeId]) {
        grouped[shift.employeeId] = {};
      }

      const shiftDate = new Date(shift.scheduledStart);
      const dayKey = formatDateForAPI(shiftDate);

      if (!grouped[shift.employeeId][dayKey]) {
        grouped[shift.employeeId][dayKey] = [];
      }

      grouped[shift.employeeId][dayKey].push(shift);
    });

    return grouped;
  }, [weeklyShifts]);

  // Navigation handlers
  const goToPreviousWeek = () => {
    const prevWeek = new Date(currentWeekStart);
    prevWeek.setDate(prevWeek.getDate() - 7);
    setCurrentWeekStart(prevWeek);
  };

  const goToNextWeek = () => {
    const nextWeek = new Date(currentWeekStart);
    nextWeek.setDate(nextWeek.getDate() + 7);
    setCurrentWeekStart(nextWeek);
  };

  const goToCurrentWeek = () => {
    setCurrentWeekStart(getWeekStart(new Date()));
  };

  // Copy previous week handler
  const handleCopyPreviousWeek = async () => {
    if (!confirm('Copy all shifts from previous week to this week?')) {
      return;
    }

    try {
      await copyPreviousWeek({ targetWeekStart: weekStartStr }).unwrap();
      alert('Previous week schedule copied successfully!');
    } catch (error: any) {
      console.error('Error copying schedule:', error);
      alert(`Failed to copy schedule: ${error?.data?.message || error.message}`);
    }
  };

  // Create single shift handler
  const handleCreateShift = async () => {
    if (!shiftFormData.employeeId || !shiftFormData.startTime || !shiftFormData.endTime) {
      alert('Please fill in all required fields');
      return;
    }

    try {
      const shiftDate = new Date(shiftFormData.date);
      const [startHour, startMin] = shiftFormData.startTime.split(':');
      const [endHour, endMin] = shiftFormData.endTime.split(':');

      const scheduledStart = new Date(shiftDate);
      scheduledStart.setHours(parseInt(startHour), parseInt(startMin), 0, 0);

      const scheduledEnd = new Date(shiftDate);
      scheduledEnd.setHours(parseInt(endHour), parseInt(endMin), 0, 0);

      const shift: CreateShiftRequest = {
        storeId,
        employeeId: shiftFormData.employeeId,
        type: shiftFormData.type,
        scheduledStart: scheduledStart.toISOString(),
        scheduledEnd: scheduledEnd.toISOString(),
        notes: shiftFormData.notes || undefined,
        isMandatory: shiftFormData.isMandatory,
      };

      await bulkCreateShifts([shift]).unwrap();
      setCreateShiftDialogOpen(false);
      setShiftFormData({
        employeeId: '',
        type: 'REGULAR',
        date: new Date(),
        startTime: '09:00',
        endTime: '17:00',
        notes: '',
        isMandatory: true,
      });
      alert('Shift created successfully!');
    } catch (error: any) {
      console.error('Error creating shift:', error);
      alert(`Failed to create shift: ${error?.data?.message || error.message}`);
    }
  };

  // Delete shift handler
  const handleDeleteShift = async (shiftId: string) => {
    if (!confirm('Are you sure you want to cancel this shift?')) {
      return;
    }

    try {
      await deleteShift(shiftId).unwrap();
      alert('Shift cancelled successfully!');
    } catch (error: any) {
      console.error('Error deleting shift:', error);
      alert(`Failed to cancel shift: ${error?.data?.message || error.message}`);
    }
  };

  // Get status color
  const getStatusColor = (status: string) => {
    switch (status) {
      case 'SCHEDULED':
        return colors.info;
      case 'CONFIRMED':
        return colors.success;
      case 'IN_PROGRESS':
        return colors.warning;
      case 'COMPLETED':
        return colors.text.secondary;
      case 'MISSED':
        return colors.error;
      case 'CANCELLED':
        return colors.text.tertiary;
      default:
        return colors.text.secondary;
    }
  };

  return (
    <>
      <AnimatedBackground variant="floating-shapes" />
      <AppHeader
        title="Staff Scheduling"
        showBackButton
        onBackClick={handleBack}
        style={{ position: 'sticky', top: 0, zIndex: 1000 }}
      />

      <div style={styles.container}>
        {/* Header Controls */}
        <Card style={styles.headerCard}>
          <div style={styles.headerContent}>
            <div style={styles.weekNavigation}>
              <Button variant="secondary" onClick={goToPreviousWeek} style={styles.navButton}>
                ← Previous Week
              </Button>
              <div style={styles.weekInfo}>
                <h2 style={styles.weekTitle}>
                  Week of {currentWeekStart.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </h2>
                <Button variant="ghost" onClick={goToCurrentWeek} style={styles.todayButton}>
                  Today
                </Button>
              </div>
              <Button variant="secondary" onClick={goToNextWeek} style={styles.navButton}>
                Next Week →
              </Button>
            </div>

            <div style={styles.actions}>
              <Button
                variant="secondary"
                onClick={handleCopyPreviousWeek}
                disabled={copying}
                style={styles.actionButton}
              >
                {copying ? 'Copying...' : 'Copy Previous Week'}
              </Button>
              <Button
                variant="primary"
                onClick={() => setCreateShiftDialogOpen(true)}
                style={styles.actionButton}
              >
                + Create Shift
              </Button>
            </div>
          </div>
        </Card>

        {/* Schedule Grid */}
        {shiftsLoading || employeesLoading ? (
          <Card style={styles.loadingCard}>
            <p>Loading schedule...</p>
          </Card>
        ) : staffMembers.length === 0 ? (
          <Card style={styles.emptyCard}>
            <p>No staff members found. Please add staff first.</p>
          </Card>
        ) : (
          <Card style={styles.scheduleCard}>
            <div style={styles.scheduleGrid}>
              {/* Header Row */}
              <div style={styles.gridHeader}>
                <div style={styles.employeeHeader}>Employee</div>
                {weekDates.map((date) => (
                  <div key={date.toISOString()} style={styles.dayHeader}>
                    <div style={styles.dayName}>{getDayName(date)}</div>
                    <div style={styles.dayDate}>{date.getDate()}</div>
                  </div>
                ))}
              </div>

              {/* Employee Rows */}
              {staffMembers.map((employee) => (
                <div key={employee.id} style={styles.employeeRow}>
                  <div style={styles.employeeCell}>
                    <div style={styles.employeeName}>{employee.name}</div>
                    <div style={styles.employeeRole}>{employee.role || employee.type}</div>
                  </div>

                  {weekDates.map((date) => {
                    const dayKey = formatDateForAPI(date);
                    const shifts = shiftsByEmployeeAndDay[employee.id]?.[dayKey] || [];

                    return (
                      <div key={dayKey} style={styles.shiftCell}>
                        {shifts.length === 0 ? (
                          <div style={styles.emptyShift}>-</div>
                        ) : (
                          shifts.map((shift) => (
                            <div
                              key={shift.id}
                              style={{
                                ...styles.shiftBadge,
                                borderLeft: `3px solid ${getStatusColor(shift.status)}`,
                              }}
                            >
                              <div style={styles.shiftTime}>
                                {formatTime(shift.scheduledStart)} - {formatTime(shift.scheduledEnd)}
                              </div>
                              <div style={styles.shiftType}>{shift.type}</div>
                              {shift.notes && (
                                <div style={styles.shiftNotes}>{shift.notes}</div>
                              )}
                              <button
                                onClick={() => handleDeleteShift(shift.id!)}
                                style={styles.deleteButton}
                                title="Cancel shift"
                              >
                                ✕
                              </button>
                            </div>
                          ))
                        )}
                      </div>
                    );
                  })}
                </div>
              ))}
            </div>
          </Card>
        )}

        {/* Create Shift Dialog */}
        {createShiftDialogOpen && (
          <div style={styles.dialogOverlay} onClick={() => setCreateShiftDialogOpen(false)}>
            <Card style={styles.dialog} onClick={(e) => e.stopPropagation()}>
              <h2 style={styles.dialogTitle}>Create New Shift</h2>

              <div style={styles.formGroup}>
                <label style={styles.label}>Employee *</label>
                <select
                  value={shiftFormData.employeeId}
                  onChange={(e) => setShiftFormData({ ...shiftFormData, employeeId: e.target.value })}
                  style={styles.select}
                >
                  <option value="">Select Employee</option>
                  {staffMembers.map((emp) => (
                    <option key={emp.id} value={emp.id}>
                      {emp.name} ({emp.role || emp.type})
                    </option>
                  ))}
                </select>
              </div>

              <div style={styles.formGroup}>
                <label style={styles.label}>Shift Type *</label>
                <select
                  value={shiftFormData.type}
                  onChange={(e) => setShiftFormData({ ...shiftFormData, type: e.target.value as any })}
                  style={styles.select}
                >
                  <option value="REGULAR">Regular</option>
                  <option value="OPENING">Opening</option>
                  <option value="CLOSING">Closing</option>
                  <option value="PEAK">Peak Hours</option>
                  <option value="MAINTENANCE">Maintenance</option>
                  <option value="TRAINING">Training</option>
                  <option value="EMERGENCY">Emergency</option>
                </select>
              </div>

              <div style={styles.formGroup}>
                <label style={styles.label}>Date *</label>
                <input
                  type="date"
                  value={formatDateForAPI(shiftFormData.date)}
                  onChange={(e) => setShiftFormData({ ...shiftFormData, date: new Date(e.target.value) })}
                  style={styles.input}
                />
              </div>

              <div style={styles.formRow}>
                <div style={styles.formGroup}>
                  <label style={styles.label}>Start Time *</label>
                  <input
                    type="time"
                    value={shiftFormData.startTime}
                    onChange={(e) => setShiftFormData({ ...shiftFormData, startTime: e.target.value })}
                    style={styles.input}
                  />
                </div>

                <div style={styles.formGroup}>
                  <label style={styles.label}>End Time *</label>
                  <input
                    type="time"
                    value={shiftFormData.endTime}
                    onChange={(e) => setShiftFormData({ ...shiftFormData, endTime: e.target.value })}
                    style={styles.input}
                  />
                </div>
              </div>

              <div style={styles.formGroup}>
                <label style={styles.label}>Notes</label>
                <textarea
                  value={shiftFormData.notes}
                  onChange={(e) => setShiftFormData({ ...shiftFormData, notes: e.target.value })}
                  style={styles.textarea}
                  rows={3}
                  placeholder="Optional notes about this shift..."
                />
              </div>

              <div style={styles.formGroup}>
                <label style={styles.checkboxLabel}>
                  <input
                    type="checkbox"
                    checked={shiftFormData.isMandatory}
                    onChange={(e) => setShiftFormData({ ...shiftFormData, isMandatory: e.target.checked })}
                  />
                  <span style={{ marginLeft: spacing.xs }}>Mandatory Shift</span>
                </label>
              </div>

              <div style={styles.dialogActions}>
                <Button variant="secondary" onClick={() => setCreateShiftDialogOpen(false)}>
                  Cancel
                </Button>
                <Button variant="primary" onClick={handleCreateShift} disabled={bulkCreating}>
                  {bulkCreating ? 'Creating...' : 'Create Shift'}
                </Button>
              </div>
            </Card>
          </div>
        )}
      </div>
    </>
  );
};

const styles: Record<string, React.CSSProperties> = {
  container: {
    padding: spacing.xl,
    maxWidth: '1600px',
    margin: '0 auto',
  },
  headerCard: {
    ...createCard(),
    marginBottom: spacing.lg,
    padding: spacing.lg,
  },
  headerContent: {
    display: 'flex',
    flexDirection: 'column',
    gap: spacing.md,
  },
  weekNavigation: {
    display: 'flex',
    alignItems: 'center',
    justifyContent: 'space-between',
    gap: spacing.md,
  },
  navButton: {
    minWidth: '150px',
  },
  weekInfo: {
    display: 'flex',
    flexDirection: 'column',
    alignItems: 'center',
    gap: spacing.xs,
  },
  weekTitle: {
    ...typography.h2,
    margin: 0,
  },
  todayButton: {
    padding: `${spacing.xs} ${spacing.sm}`,
  },
  actions: {
    display: 'flex',
    gap: spacing.md,
    justifyContent: 'flex-end',
  },
  actionButton: {
    minWidth: '150px',
  },
  loadingCard: {
    ...createCard(),
    padding: spacing.xl,
    textAlign: 'center',
  },
  emptyCard: {
    ...createCard(),
    padding: spacing.xl,
    textAlign: 'center',
  },
  scheduleCard: {
    ...createCard(),
    padding: spacing.lg,
    overflowX: 'auto',
  },
  scheduleGrid: {
    display: 'flex',
    flexDirection: 'column',
    minWidth: '1200px',
  },
  gridHeader: {
    display: 'grid',
    gridTemplateColumns: '200px repeat(7, 1fr)',
    gap: spacing.sm,
    marginBottom: spacing.md,
    paddingBottom: spacing.sm,
    borderBottom: `2px solid ${colors.surface.border}`,
  },
  employeeHeader: {
    ...typography.label,
    fontWeight: typography.fontWeight.bold,
    padding: spacing.sm,
  },
  dayHeader: {
    ...typography.label,
    fontWeight: typography.fontWeight.bold,
    textAlign: 'center',
    padding: spacing.sm,
  },
  dayName: {
    fontSize: typography.fontSizes.sm,
  },
  dayDate: {
    fontSize: typography.fontSizes.lg,
    marginTop: spacing.xs,
  },
  employeeRow: {
    display: 'grid',
    gridTemplateColumns: '200px repeat(7, 1fr)',
    gap: spacing.sm,
    marginBottom: spacing.sm,
  },
  employeeCell: {
    padding: spacing.sm,
    display: 'flex',
    flexDirection: 'column',
    justifyContent: 'center',
  },
  employeeName: {
    ...typography.body,
    fontWeight: typography.fontWeight.medium,
  },
  employeeRole: {
    ...typography.caption,
    color: colors.text.secondary,
    marginTop: spacing.xs,
  },
  shiftCell: {
    ...createNeumorphicSurface({
      depth: 'flat',
      radius: borderRadius.sm,
    }),
    padding: spacing.xs,
    minHeight: '80px',
    display: 'flex',
    flexDirection: 'column',
    gap: spacing.xs,
  },
  emptyShift: {
    display: 'flex',
    alignItems: 'center',
    justifyContent: 'center',
    height: '100%',
    color: colors.text.tertiary,
    fontSize: typography.fontSizes.lg,
  },
  shiftBadge: {
    ...createBadge(colors.background.surface),
    padding: spacing.xs,
    position: 'relative',
    display: 'flex',
    flexDirection: 'column',
    gap: '2px',
  },
  shiftTime: {
    ...typography.caption,
    fontWeight: typography.fontWeight.medium,
    fontSize: typography.fontSizes.xs,
  },
  shiftType: {
    ...typography.caption,
    fontSize: typography.fontSizes.xs,
    color: colors.text.secondary,
  },
  shiftNotes: {
    ...typography.caption,
    fontSize: typography.fontSizes.xs,
    color: colors.text.tertiary,
    fontStyle: 'italic',
    marginTop: spacing.xs,
  },
  deleteButton: {
    position: 'absolute',
    top: '4px',
    right: '4px',
    background: colors.error,
    color: colors.text.inverse,
    border: 'none',
    borderRadius: borderRadius.xs,
    width: '20px',
    height: '20px',
    display: 'flex',
    alignItems: 'center',
    justifyContent: 'center',
    cursor: 'pointer',
    fontSize: '12px',
    opacity: 0.7,
    transition: 'opacity 0.2s',
  },
  dialogOverlay: {
    position: 'fixed',
    top: 0,
    left: 0,
    right: 0,
    bottom: 0,
    backgroundColor: 'rgba(0, 0, 0, 0.5)',
    display: 'flex',
    alignItems: 'center',
    justifyContent: 'center',
    zIndex: 2000,
  },
  dialog: {
    ...createCard(),
    width: '100%',
    maxWidth: '600px',
    maxHeight: '90vh',
    overflowY: 'auto',
    padding: spacing.xl,
    margin: spacing.lg,
  },
  dialogTitle: {
    ...typography.h2,
    marginBottom: spacing.lg,
  },
  formGroup: {
    marginBottom: spacing.md,
  },
  formRow: {
    display: 'grid',
    gridTemplateColumns: '1fr 1fr',
    gap: spacing.md,
  },
  label: {
    ...typography.label,
    display: 'block',
    marginBottom: spacing.xs,
  },
  input: {
    ...createNeumorphicSurface({
      depth: 'inset',
      radius: borderRadius.sm,
    }),
    width: '100%',
    padding: spacing.sm,
    fontSize: typography.fontSizes.md,
    border: 'none',
    outline: 'none',
  },
  select: {
    ...createNeumorphicSurface({
      depth: 'inset',
      radius: borderRadius.sm,
    }),
    width: '100%',
    padding: spacing.sm,
    fontSize: typography.fontSizes.md,
    border: 'none',
    outline: 'none',
  },
  textarea: {
    ...createNeumorphicSurface({
      depth: 'inset',
      radius: borderRadius.sm,
    }),
    width: '100%',
    padding: spacing.sm,
    fontSize: typography.fontSizes.md,
    border: 'none',
    outline: 'none',
    fontFamily: 'inherit',
    resize: 'vertical',
  },
  checkboxLabel: {
    ...typography.body,
    display: 'flex',
    alignItems: 'center',
    cursor: 'pointer',
  },
  dialogActions: {
    display: 'flex',
    gap: spacing.md,
    justifyContent: 'flex-end',
    marginTop: spacing.lg,
    paddingTop: spacing.lg,
    borderTop: `1px solid ${colors.surface.border}`,
  },
};

export default withPageStoreContext(StaffSchedulingPage, 'staff-scheduling');
