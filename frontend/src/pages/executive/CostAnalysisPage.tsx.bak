import React, { useEffect, useState } from 'react';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Badge } from '@/components/ui/badge';
import { DollarSign, TrendingUp, TrendingDown, AlertTriangle, Package } from 'lucide-react';
import axios from 'axios';
import API_CONFIG from '../../config/api.config';

interface CostAnalysis {
  period: string;
  totalRevenue: number;
  totalCosts: number;
  totalProfit: number;
  profitMargin: number;
  costBreakdown: {
    ingredientCosts: number;
    wasteCosts: number;
    laborCosts: number;
    overheadCosts: number;
    deliveryCosts: number;
    otherCosts: number;
  };
  ingredientCosts: Array<{
    ingredientId: string;
    ingredientName: string;
    quantityUsed: number;
    unit: string;
    costPerUnit: number;
    totalCost: number;
    percentOfTotalCost: number;
    trend: string;
  }>;
  wasteCosts: Array<{
    itemName: string;
    quantityWasted: number;
    unit: string;
    estimatedCost: number;
    reason: string;
    date: string;
  }>;
  topCostOrders: Array<{
    orderId: string;
    revenue: number;
    cost: number;
    profit: number;
    profitMargin: number;
    itemCount: number;
  }>;
  supplierComparisons: Array<{
    ingredientName: string;
    suppliers: Array<{
      supplierId: string;
      supplierName: string;
      pricePerUnit: number;
      unit: string;
      quality: string;
      deliveryDays: number;
    }>;
    recommendedSupplier: string;
    potentialSavings: number;
  }>;
}

const CostAnalysisPage: React.FC = () => {
  const [analysis, setAnalysis] = useState<CostAnalysis | null>(null);
  const [loading, setLoading] = useState(true);
  const [period, setPeriod] = useState<string>('MONTH');

  useEffect(() => {
    fetchCostAnalysis();
  }, [period]);

  const fetchCostAnalysis = async () => {
    try {
      setLoading(true);
      const response = await axios.get<CostAnalysis>(`${API_CONFIG.BASE_URL}/bi/cost-analysis?period=${period}`);
      setAnalysis(response.data);
    } catch (error) {
      console.error('Failed to fetch cost analysis:', error);
    } finally {
      setLoading(false);
    }
  };

  const formatCurrency = (value: number): string => {
    return new Intl.NumberFormat('en-IN', {
      style: 'currency',
      currency: 'INR',
      maximumFractionDigits: 0,
    }).format(value);
  };

  const getTrendIcon = (trend: string) => {
    return trend === 'UP' ? (
      <TrendingUp className="h-4 w-4 text-red-600" />
    ) : trend === 'DOWN' ? (
      <TrendingDown className="h-4 w-4 text-green-600" />
    ) : null;
  };

  const getQualityColor = (quality: string): string => {
    switch (quality) {
      case 'Premium': return 'bg-purple-100 text-purple-800';
      case 'Standard': return 'bg-blue-100 text-blue-800';
      case 'Budget': return 'bg-green-100 text-green-800';
      default: return 'bg-gray-100 text-gray-800';
    }
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center h-screen">
        <div className="text-lg">Loading Cost Analysis...</div>
      </div>
    );
  }

  if (!analysis) {
    return (
      <div className="flex items-center justify-center h-screen">
        <div className="text-lg text-red-600">Failed to load data</div>
      </div>
    );
  }

  const costBreakdownData = [
    { label: 'Ingredients', value: analysis.costBreakdown.ingredientCosts, color: 'bg-blue-500' },
    { label: 'Labor', value: analysis.costBreakdown.laborCosts, color: 'bg-green-500' },
    { label: 'Overhead', value: analysis.costBreakdown.overheadCosts, color: 'bg-yellow-500' },
    { label: 'Delivery', value: analysis.costBreakdown.deliveryCosts, color: 'bg-purple-500' },
    { label: 'Waste', value: analysis.costBreakdown.wasteCosts, color: 'bg-red-500' },
    { label: 'Other', value: analysis.costBreakdown.otherCosts, color: 'bg-gray-500' },
  ];

  return (
    <div className="container mx-auto p-6 space-y-6 bg-gray-50 min-h-screen">
      {/* Header */}
      <div className="flex justify-between items-center">
        <div>
          <h1 className="text-3xl font-bold text-gray-900">Cost Analysis</h1>
          <p className="text-gray-600 mt-1">Comprehensive cost breakdown and insights</p>
        </div>
        <div className="flex gap-2">
          {['TODAY', 'WEEK', 'MONTH'].map((p) => (
            <button
              key={p}
              onClick={() => setPeriod(p)}
              className={`px-4 py-2 rounded-lg ${
                period === p
                  ? 'bg-blue-600 text-white'
                  : 'bg-white text-gray-700 border border-gray-300'
              }`}
            >
              {p}
            </button>
          ))}
        </div>
      </div>

      {/* Summary Cards */}
      <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
        <Card>
          <CardContent className="pt-6">
            <div className="flex items-center gap-2 mb-2">
              <DollarSign className="h-5 w-5 text-green-600" />
              <div className="text-sm font-medium text-gray-600">Total Revenue</div>
            </div>
            <div className="text-2xl font-bold text-green-600">
              {formatCurrency(analysis.totalRevenue)}
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="pt-6">
            <div className="flex items-center gap-2 mb-2">
              <Package className="h-5 w-5 text-red-600" />
              <div className="text-sm font-medium text-gray-600">Total Costs</div>
            </div>
            <div className="text-2xl font-bold text-red-600">
              {formatCurrency(analysis.totalCosts)}
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="pt-6">
            <div className="flex items-center gap-2 mb-2">
              <TrendingUp className="h-5 w-5 text-blue-600" />
              <div className="text-sm font-medium text-gray-600">Total Profit</div>
            </div>
            <div className="text-2xl font-bold text-blue-600">
              {formatCurrency(analysis.totalProfit)}
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="pt-6">
            <div className="text-sm font-medium text-gray-600 mb-2">Profit Margin</div>
            <div className="text-2xl font-bold">
              {analysis.profitMargin.toFixed(2)}%
            </div>
            <div className="mt-2 text-xs text-gray-500">
              {analysis.profitMargin >= 20 ? 'Excellent' : analysis.profitMargin >= 15 ? 'Good' : 'Needs Improvement'}
            </div>
          </CardContent>
        </Card>
      </div>

      {/* Tabs */}
      <Tabs defaultValue="breakdown" className="space-y-4">
        <TabsList className="bg-white">
          <TabsTrigger value="breakdown">Cost Breakdown</TabsTrigger>
          <TabsTrigger value="ingredients">Ingredients</TabsTrigger>
          <TabsTrigger value="waste">Waste Analysis</TabsTrigger>
          <TabsTrigger value="orders">Order Costs</TabsTrigger>
          <TabsTrigger value="suppliers">Suppliers</TabsTrigger>
        </TabsList>

        {/* Cost Breakdown Tab */}
        <TabsContent value="breakdown" className="space-y-4">
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <Card>
              <CardHeader>
                <CardTitle>Cost Distribution</CardTitle>
              </CardHeader>
              <CardContent className="space-y-4">
                {costBreakdownData.map((item) => {
                  const percentage = (item.value / analysis.totalCosts) * 100;
                  return (
                    <div key={item.label} className="space-y-1">
                      <div className="flex justify-between text-sm">
                        <span className="font-medium">{item.label}</span>
                        <span className="text-gray-600">{formatCurrency(item.value)}</span>
                      </div>
                      <div className="w-full bg-gray-200 rounded-full h-3">
                        <div
                          className={`${item.color} h-3 rounded-full transition-all`}
                          style={{ width: `${percentage}%` }}
                        />
                      </div>
                      <div className="text-xs text-gray-500">{percentage.toFixed(1)}% of total costs</div>
                    </div>
                  );
                })}
              </CardContent>
            </Card>

            <Card>
              <CardHeader>
                <CardTitle>Cost Breakdown Summary</CardTitle>
              </CardHeader>
              <CardContent className="space-y-2">
                {costBreakdownData.map((item) => (
                  <div key={item.label} className="flex justify-between border-b pb-2">
                    <span className="text-gray-600">{item.label}</span>
                    <span className="font-semibold">{formatCurrency(item.value)}</span>
                  </div>
                ))}
                <div className="flex justify-between pt-2 border-t-2 font-bold">
                  <span>Total</span>
                  <span>{formatCurrency(analysis.totalCosts)}</span>
                </div>
              </CardContent>
            </Card>
          </div>
        </TabsContent>

        {/* Ingredients Tab */}
        <TabsContent value="ingredients" className="space-y-4">
          <Card>
            <CardHeader>
              <CardTitle>Ingredient Cost Analysis</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="overflow-x-auto">
                <table className="w-full">
                  <thead className="bg-gray-50">
                    <tr>
                      <th className="text-left p-3 font-semibold">Ingredient</th>
                      <th className="text-right p-3 font-semibold">Qty Used</th>
                      <th className="text-right p-3 font-semibold">Cost/Unit</th>
                      <th className="text-right p-3 font-semibold">Total Cost</th>
                      <th className="text-right p-3 font-semibold">% of Total</th>
                      <th className="text-center p-3 font-semibold">Trend</th>
                    </tr>
                  </thead>
                  <tbody>
                    {analysis.ingredientCosts.map((ingredient, index) => (
                      <tr key={index} className="border-b hover:bg-gray-50">
                        <td className="p-3 font-medium">{ingredient.ingredientName}</td>
                        <td className="p-3 text-right">
                          {ingredient.quantityUsed.toFixed(2)} {ingredient.unit}
                        </td>
                        <td className="p-3 text-right">{formatCurrency(ingredient.costPerUnit)}</td>
                        <td className="p-3 text-right font-semibold">
                          {formatCurrency(ingredient.totalCost)}
                        </td>
                        <td className="p-3 text-right">{ingredient.percentOfTotalCost.toFixed(1)}%</td>
                        <td className="p-3 flex justify-center">{getTrendIcon(ingredient.trend)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </CardContent>
          </Card>
        </TabsContent>

        {/* Waste Analysis Tab */}
        <TabsContent value="waste" className="space-y-4">
          <Card>
            <CardHeader>
              <CardTitle className="flex items-center gap-2">
                <AlertTriangle className="h-5 w-5 text-red-600" />
                Waste Cost Analysis
              </CardTitle>
            </CardHeader>
            <CardContent>
              <div className="space-y-4">
                {analysis.wasteCosts.map((waste, index) => (
                  <div key={index} className="border-l-4 border-red-500 bg-red-50 p-4 rounded">
                    <div className="flex justify-between items-start mb-2">
                      <div>
                        <h4 className="font-semibold text-gray-900">{waste.itemName}</h4>
                        <p className="text-sm text-gray-600">
                          {waste.quantityWasted.toFixed(2)} {waste.unit} wasted
                        </p>
                      </div>
                      <div className="text-right">
                        <div className="font-bold text-red-600">
                          {formatCurrency(waste.estimatedCost)}
                        </div>
                        <Badge className="mt-1 bg-yellow-100 text-yellow-800">
                          {waste.reason}
                        </Badge>
                      </div>
                    </div>
                    <div className="text-xs text-gray-500">
                      Date: {new Date(waste.date).toLocaleDateString()}
                    </div>
                  </div>
                ))}
                {analysis.wasteCosts.length === 0 && (
                  <div className="text-center text-gray-500 py-8">
                    No waste recorded for this period
                  </div>
                )}
              </div>
            </CardContent>
          </Card>
        </TabsContent>

        {/* Order Costs Tab */}
        <TabsContent value="orders" className="space-y-4">
          <Card>
            <CardHeader>
              <CardTitle>Top Cost Orders</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="overflow-x-auto">
                <table className="w-full">
                  <thead className="bg-gray-50">
                    <tr>
                      <th className="text-left p-3 font-semibold">Order ID</th>
                      <th className="text-right p-3 font-semibold">Revenue</th>
                      <th className="text-right p-3 font-semibold">Cost</th>
                      <th className="text-right p-3 font-semibold">Profit</th>
                      <th className="text-right p-3 font-semibold">Margin %</th>
                      <th className="text-center p-3 font-semibold">Items</th>
                    </tr>
                  </thead>
                  <tbody>
                    {analysis.topCostOrders.map((order, index) => (
                      <tr key={index} className="border-b hover:bg-gray-50">
                        <td className="p-3 font-mono text-sm">{order.orderId.substring(0, 8)}</td>
                        <td className="p-3 text-right">{formatCurrency(order.revenue)}</td>
                        <td className="p-3 text-right text-red-600">{formatCurrency(order.cost)}</td>
                        <td className="p-3 text-right font-semibold text-green-600">
                          {formatCurrency(order.profit)}
                        </td>
                        <td className="p-3 text-right">
                          <Badge
                            className={
                              order.profitMargin >= 30
                                ? 'bg-green-100 text-green-800'
                                : order.profitMargin >= 20
                                ? 'bg-blue-100 text-blue-800'
                                : 'bg-yellow-100 text-yellow-800'
                            }
                          >
                            {order.profitMargin.toFixed(1)}%
                          </Badge>
                        </td>
                        <td className="p-3 text-center">{order.itemCount}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </CardContent>
          </Card>
        </TabsContent>

        {/* Suppliers Tab */}
        <TabsContent value="suppliers" className="space-y-4">
          {analysis.supplierComparisons.map((comparison, index) => (
            <Card key={index}>
              <CardHeader>
                <CardTitle>{comparison.ingredientName}</CardTitle>
                <div className="text-sm text-gray-600">
                  Potential savings: {formatCurrency(comparison.potentialSavings)}/month
                </div>
              </CardHeader>
              <CardContent>
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                  {comparison.suppliers.map((supplier, idx) => (
                    <div
                      key={idx}
                      className={`border rounded-lg p-4 ${
                        supplier.supplierId === comparison.recommendedSupplier
                          ? 'border-green-500 bg-green-50'
                          : 'border-gray-200'
                      }`}
                    >
                      {supplier.supplierId === comparison.recommendedSupplier && (
                        <Badge className="mb-2 bg-green-100 text-green-800">Recommended</Badge>
                      )}
                      <h4 className="font-semibold mb-2">{supplier.supplierName}</h4>
                      <div className="space-y-1 text-sm">
                        <div className="flex justify-between">
                          <span className="text-gray-600">Price:</span>
                          <span className="font-semibold">
                            {formatCurrency(supplier.pricePerUnit)}/{supplier.unit}
                          </span>
                        </div>
                        <div className="flex justify-between">
                          <span className="text-gray-600">Quality:</span>
                          <Badge className={getQualityColor(supplier.quality)}>
                            {supplier.quality}
                          </Badge>
                        </div>
                        <div className="flex justify-between">
                          <span className="text-gray-600">Delivery:</span>
                          <span>{supplier.deliveryDays} days</span>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </CardContent>
            </Card>
          ))}
        </TabsContent>
      </Tabs>
    </div>
  );
};

export default CostAnalysisPage;
