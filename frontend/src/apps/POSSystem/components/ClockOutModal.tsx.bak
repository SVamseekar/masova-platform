// src/apps/POSSystem/components/ClockOutModal.tsx
import React, { useState, useEffect } from 'react';
import { colors, shadows, spacing, typography } from '../../../styles/design-tokens';
import Button from '../../../components/ui/neumorphic/Button';
import { useGetActiveStoreSessionsQuery, useClockOutEmployeeMutation } from '../../../store/api/sessionApi';

interface ClockOutModalProps {
  isOpen: boolean;
  onClose: () => void;
  storeId: string;
}

const ClockOutModal: React.FC<ClockOutModalProps> = ({ isOpen, onClose, storeId }) => {
  const [selectedEmployee, setSelectedEmployee] = useState<string>('');
  const [error, setError] = useState<string>('');
  const [success, setSuccess] = useState<string>('');

  // Fetch active sessions
  const { data: activeSessions = [], refetch } = useGetActiveStoreSessionsQuery(storeId, {
    skip: !storeId || !isOpen
  });

  const [clockOutEmployee, { isLoading: isClockingOut }] = useClockOutEmployeeMutation();

  useEffect(() => {
    if (isOpen) {
      setSelectedEmployee('');
      setError('');
      setSuccess('');
      refetch();
    }
  }, [isOpen, refetch]);

  const handleClockOut = async () => {
    setError('');
    setSuccess('');

    if (!selectedEmployee) {
      setError('Please select an employee');
      return;
    }

    const session = activeSessions.find((s: any) => s.employeeId === selectedEmployee);
    if (!session) {
      setError('Employee session not found');
      return;
    }

    if (!confirm(`Are you sure you want to clock out ${session.employeeName || session.name}?`)) {
      return;
    }

    try {
      const result = await clockOutEmployee({ employeeId: selectedEmployee }).unwrap();
      setSuccess(result.message || 'Employee clocked out successfully!');

      // Clear form and close after 2 seconds
      setTimeout(() => {
        setSelectedEmployee('');
        refetch();
        onClose();
      }, 2000);
    } catch (err: any) {
      setError(err?.data?.error || 'Failed to clock out employee');
    }
  };

  const formatDuration = (loginTime: string) => {
    const start = new Date(loginTime);
    const now = new Date();
    const diffMs = now.getTime() - start.getTime();
    const hours = Math.floor(diffMs / (1000 * 60 * 60));
    const minutes = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
    return `${hours}h ${minutes}m`;
  };

  if (!isOpen) return null;

  return (
    <div style={styles.overlay}>
      <div style={styles.modal}>
        <div style={styles.header}>
          <h2 style={styles.title}>Clock Out Employee</h2>
          <button onClick={onClose} style={styles.closeButton}>×</button>
        </div>

        <div style={styles.content}>
          {/* Employee Selection */}
          <div style={styles.formGroup}>
            <label style={styles.label}>Select Employee to Clock Out</label>
            {activeSessions.length === 0 ? (
              <div style={styles.emptyState}>
                <p style={styles.emptyText}>No employees are currently clocked in</p>
              </div>
            ) : (
              <div style={styles.employeeList}>
                {activeSessions.map((session: any) => (
                  <button
                    key={session.employeeId}
                    onClick={() => setSelectedEmployee(session.employeeId)}
                    style={{
                      ...styles.employeeCard,
                      ...(selectedEmployee === session.employeeId ? styles.employeeCardSelected : {})
                    }}
                  >
                    <div style={styles.employeeInfo}>
                      <div style={styles.avatar}>
                        {(session.employeeName || session.name)?.charAt(0).toUpperCase() || 'E'}
                      </div>
                      <div style={styles.employeeDetails}>
                        <div style={styles.employeeName}>
                          {session.employeeName || session.name || 'Employee'}
                        </div>
                        <div style={styles.employeeRole}>
                          {session.role || 'Staff'}
                        </div>
                      </div>
                    </div>
                    <div style={styles.sessionTime}>
                      <div style={styles.timeLabel}>Duration</div>
                      <div style={styles.timeValue}>{formatDuration(session.loginTime)}</div>
                    </div>
                  </button>
                ))}
              </div>
            )}
          </div>

          {/* Error Message */}
          {error && (
            <div style={styles.errorMessage}>
              {error}
            </div>
          )}

          {/* Success Message */}
          {success && (
            <div style={styles.successMessage}>
              ✓ {success}
            </div>
          )}

          {/* Actions */}
          <div style={styles.actions}>
            <Button
              variant="secondary"
              onClick={onClose}
              disabled={isClockingOut}
            >
              Cancel
            </Button>
            <Button
              variant="primary"
              onClick={handleClockOut}
              disabled={isClockingOut || !selectedEmployee || activeSessions.length === 0}
            >
              {isClockingOut ? 'Clocking Out...' : 'Clock Out'}
            </Button>
          </div>
        </div>
      </div>
    </div>
  );
};

const styles: Record<string, React.CSSProperties> = {
  overlay: {
    position: 'fixed',
    top: 0,
    left: 0,
    right: 0,
    bottom: 0,
    backgroundColor: 'rgba(0, 0, 0, 0.5)',
    display: 'flex',
    alignItems: 'center',
    justifyContent: 'center',
    zIndex: 1000,
  },
  modal: {
    backgroundColor: colors.surface.background,
    borderRadius: '16px',
    boxShadow: shadows.raised.md,
    width: '90%',
    maxWidth: '600px',
    maxHeight: '90vh',
    overflow: 'auto',
  },
  header: {
    display: 'flex',
    justifyContent: 'space-between',
    alignItems: 'center',
    padding: spacing[6],
    borderBottom: `1px solid ${colors.surface.border}`,
  },
  title: {
    margin: 0,
    fontSize: '24px',
    fontWeight: 600,
    color: colors.text.primary,
  },
  closeButton: {
    background: 'none',
    border: 'none',
    fontSize: '32px',
    cursor: 'pointer',
    color: colors.text.secondary,
    padding: 0,
    width: '32px',
    height: '32px',
    display: 'flex',
    alignItems: 'center',
    justifyContent: 'center',
  },
  content: {
    padding: spacing[6],
  },
  formGroup: {
    marginBottom: spacing[6],
  },
  label: {
    display: 'block',
    marginBottom: spacing[4],
    fontSize: '14px',
    fontWeight: 500,
    color: colors.text.primary,
  },
  employeeList: {
    display: 'flex',
    flexDirection: 'column',
    gap: spacing[3],
    maxHeight: '400px',
    overflowY: 'auto',
  },
  employeeCard: {
    display: 'flex',
    justifyContent: 'space-between',
    alignItems: 'center',
    padding: spacing[4],
    border: `2px solid ${colors.surface.border}`,
    borderRadius: '12px',
    backgroundColor: colors.surface.secondary,
    cursor: 'pointer',
    transition: 'all 0.2s ease',
    textAlign: 'left',
  },
  employeeCardSelected: {
    borderColor: colors.brand.primary,
    backgroundColor: colors.brand.primaryLight || '#e0e7ff',
  },
  employeeInfo: {
    display: 'flex',
    alignItems: 'center',
    gap: spacing[3],
  },
  avatar: {
    width: '48px',
    height: '48px',
    borderRadius: '50%',
    backgroundColor: colors.brand.primary,
    color: '#FFFFFF',
    display: 'flex',
    alignItems: 'center',
    justifyContent: 'center',
    fontSize: '20px',
    fontWeight: 600,
  },
  employeeDetails: {
    display: 'flex',
    flexDirection: 'column',
    gap: spacing[1],
  },
  employeeName: {
    fontSize: typography.fontSize.base,
    fontWeight: typography.fontWeight.semibold,
    color: colors.text.primary,
  },
  employeeRole: {
    fontSize: typography.fontSize.sm,
    color: colors.text.secondary,
  },
  sessionTime: {
    textAlign: 'right',
  },
  timeLabel: {
    fontSize: typography.fontSize.xs,
    color: colors.text.tertiary,
    marginBottom: spacing[1],
  },
  timeValue: {
    fontSize: typography.fontSize.base,
    fontWeight: typography.fontWeight.bold,
    color: colors.brand.primary,
  },
  emptyState: {
    textAlign: 'center',
    padding: spacing[8],
    backgroundColor: colors.surface.secondary,
    borderRadius: '12px',
  },
  emptyText: {
    fontSize: '16px',
    color: colors.text.secondary,
    margin: 0,
  },
  errorMessage: {
    padding: spacing[4],
    backgroundColor: '#fee',
    color: '#c33',
    borderRadius: '8px',
    marginBottom: spacing[4],
    fontSize: '14px',
  },
  successMessage: {
    padding: spacing[4],
    backgroundColor: '#efe',
    color: '#3c3',
    borderRadius: '8px',
    marginBottom: spacing[4],
    fontSize: '14px',
  },
  actions: {
    display: 'flex',
    gap: spacing[4],
    justifyContent: 'flex-end',
    marginTop: spacing[6],
  },
};

export default ClockOutModal;
