{
  "consumer": {
    "name": "masova-frontend"
  },
  "interactions": [
    {
      "description": "a request to get available drivers",
      "pending": false,
      "providerStates": [
        {
          "name": "drivers are available"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/delivery/drivers/available"
      },
      "response": {
        "body": {
          "content": [
            {
              "id": "driver-1",
              "name": "Rajesh Kumar",
              "rating": 4.8,
              "status": "AVAILABLE"
            }
          ],
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].rating": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    },
    {
      "description": "a request to track delivery",
      "pending": false,
      "providerStates": [
        {
          "name": "delivery tracking exists for order order-track-1"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/delivery/track/order-track-1"
      },
      "response": {
        "body": {
          "content": {
            "driverName": "Rajesh Driver",
            "estimatedMinutes": 15,
            "orderId": "order-track-1",
            "status": "IN_TRANSIT"
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.driverName": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.estimatedMinutes": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.orderId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pactRust": {
      "ffi": "0.4.28",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "logistics-service"
  }
}