      "pending": false,
      "providerStates": [
        {
          "name": "customers exist"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/customers"
      },
      "response": {
        "body": {
          "content": [
            {
              "active": true,
              "email": "customer@masova.com",
              "id": "cust-1"
            }
          ],
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
