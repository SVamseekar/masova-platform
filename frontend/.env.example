# ============================================
# MaSoVa Restaurant Management System
# Frontend Environment Variables (Vite)
# ============================================

# --------------------------------------------
# API Configuration (REQUIRED)
# --------------------------------------------
# API Gateway URL - All backend requests go through this gateway
# Do NOT use direct service URLs - security and routing handled by gateway
VITE_API_GATEWAY_URL=http://localhost:8080/api

# WebSocket URL for real-time features
# Used for: Kitchen Display System, Order Tracking, Driver Location Updates
VITE_WS_URL=http://localhost:8083/ws

# --------------------------------------------
# Application Environment
# --------------------------------------------
VITE_ENV=development

# --------------------------------------------
# External Service Keys
# --------------------------------------------
# Google Maps API Key (for driver navigation and delivery tracking)
# Get your key from: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Directions API, Geocoding API
# Free tier: $200/month credit
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Payment Gateway - Razorpay (for online payments)
# Get your keys from: https://dashboard.razorpay.com/app/keys
# Use test keys for development (rzp_test_...)
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE

# --------------------------------------------
# Production Configuration (Optional)
# --------------------------------------------
# Uncomment and set these for production deployment
# VITE_API_GATEWAY_URL=https://api.yourdomain.com/api
# VITE_WS_URL=wss://api.yourdomain.com/ws
# VITE_ENV=production
# VITE_RAZORPAY_KEY_ID=rzp_live_YOUR_LIVE_KEY_HERE

# --------------------------------------------
# IMPORTANT NOTES
# --------------------------------------------
# 1. All Vite environment variables MUST start with "VITE_" prefix
# 2. Never commit .env file to git (already in .gitignore)
# 3. For production, set these in your hosting platform's environment config
# 4. VITE_API_GATEWAY_URL and VITE_WS_URL are REQUIRED - app will fail without them
# 5. Copy this file to .env and fill in your actual values
